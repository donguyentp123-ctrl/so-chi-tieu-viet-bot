generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  EXPENSE
  INCOME
}

model User {
  id         String        @id
  firstName String?
  username  String?
  createdAt DateTime      @default(now())

  records   Transaction[]
  wallets   Wallet[]
  budgets   Budget[]
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String
  name      String
  balance   Int      @default(0)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

model Transaction {
  id        String          @id @default(uuid())
  userId    String
  walletId  String?
  type      TransactionType
  amount    Int
  category  String
  note      String?
  createdAt DateTime        @default(now())

  user      User            @relation(fields: [userId], references: [id])
  wallet    Wallet?         @relation(fields: [walletId], references: [id])
}

model Budget {
  id        String   @id @default(uuid())
  userId    String
  category  String
  amount    Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}